# Spring Boot server
SERVER_PORT=8081

# CORS: default is localhost-safe. Add your Vercel/ngrok domain for demo without touching code.
# Example: CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*,https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*,http://[::1]:*

# Database (overrides spring.datasource.* in application.yml)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/greenplanep2?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&useUnicode=true&characterEncoding=utf8&connectionCollation=utf8mb4_0900_ai_ci&sessionVariables=character_set_client=utf8mb4,character_set_connection=utf8mb4,character_set_results=utf8mb4
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=mysql123456


